# Claude API Key（必填）—— https://console.anthropic.com 获取
ANTHROPIC_API_KEY=sk-ant-xxxxx

# 可选：覆盖默认模型
ANTHROPIC_MODEL=claude-opus-4-8

# 可选：服务端口
PORT=3000

# —— 实时录音通道（ASR）——
# mock = 无需密钥联调整条链路；openai_compatible = 任何 OpenAI 兼容转写服务
# （OpenAI Whisper / Groq / SiliconFlow(国内) / 自托管 faster-whisper 等）
ASR_PROVIDER=mock
# ASR_BASE_URL=https://api.openai.com/v1
# ASR_API_KEY=sk-xxxxx
# ASR_MODEL=whisper-1

# 可选：滚动分析节奏（毫秒 / 新增字符数）
# ANALYZE_MIN_INTERVAL_MS=10000
# ANALYZE_MIN_NEW_CHARS=20
